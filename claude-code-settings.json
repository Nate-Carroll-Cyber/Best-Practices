{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(command -v *)",
      "Bash(curl -fsS http://127.0.0.1:*)",
      "Bash(curl -s http://127.0.0.1:*)",
      "Bash(curl -sf http://127.0.0.1:*)",
      "Bash(diff *)",
      "Bash(docker compose * config *)",
      "Bash(docker compose * ps)",
      "Bash(docker inspect *)",
      "Bash(docker logs *)",
      "Bash(docker ps *)",
      "Bash(find *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git check-ignore *)",
      "Bash(git diff *)",
      "Bash(git grep *)",
      "Bash(git log *)",
      "Bash(git merge-base *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(mkdir -p *)",
      "Bash(node --version)",
      "Bash(npm ls *)",
      "Bash(npm run backend:build)",
      "Bash(npm run backend:check)",
      "Bash(npm run backend:test)",
      "Bash(npm run build)",
      "Bash(npm run build:all)",
      "Bash(npm run build:client)",
      "Bash(npm run build:ssr)",
      "Bash(npm run gateway:check)",
      "Bash(npm run gateway:test)",
      "Bash(npm run lint)",
      "Bash(npm run sam-spade:test)",
      "Bash(npm run shared:build)",
      "Bash(npm test)",
      "Bash(npm view *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx vite --version)",
      "Bash(pwd)",
      "Bash(sed -n *)",
      "Bash(sleep *)",
      "Bash(tail *)",
      "Bash(wc -l *)",
      "Bash(which *)"
    ],
    "deny": [
      "Bash(git clean *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(rm)",
      "Bash(rm *)",
      "Bash(sudo *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/hosts.yml)"
    ],
    "ask": [
      "Bash(chmod *)",
      "Bash(cp *)",
      "Bash(docker compose * build *)",
      "Bash(docker compose * down *)",
      "Bash(docker compose * stop *)",
      "Bash(docker compose * up *)",
      "Bash(docker exec *)",
      "Bash(docker start *)",
      "Bash(docker stop *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git commit --amend *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(kill *)",
      "Bash(node -e *)",
      "Bash(node --import *)",
      "Bash(npm install *)",
      "Bash(perl *)",
      "Bash(python3 *)",
      "Bash(rmdir *)",
      "Bash(sed -i *)"
    ]
  },
  "agentPushNotifEnabled": true
}
